class_name EnemyData
extends Resource

## Конфигурационный ресурс врага. Сохраняется как .tres файл в assets/data/enemies/.
## [br]
## Один ресурс на архетип. Масштабирование при спавне:
## [code]final_stat = base_stat * smoothing_multiplier(dungeon_level)[/code]
## [br]
## GDD: [code]design/gdd/enemy-ai.md[/code]

# ---------------------------------------------------------------------------
# Идентификация
# ---------------------------------------------------------------------------

## Отображаемое имя врага (для UI).
@export var display_name: String = "Enemy"

## Тип архетипа — определяет поведение в BaseEnemy.
@export_enum("MELEE", "RANGED", "ELITE") var enemy_type: int = 0

# ---------------------------------------------------------------------------
# Боевые параметры
# ---------------------------------------------------------------------------

## Максимальный HP.
@export var max_hp: float = 50.0

## Скорость перемещения (px/s).
@export var move_speed: float = 90.0

## Урон базовой атаки.
@export var attack_damage: float = 12.0

## Дистанция атаки (px). Melee: 60, Ranged — preferred range.
@export var attack_range: float = 60.0

## Задержка между атаками (с).
@export var attack_cooldown: float = 1.0

## Задержка windup телеграфа перед атакой (с). Melee/Ranged: 0.4с.
@export var attack_windup: float = 0.4

# ---------------------------------------------------------------------------
# Обнаружение
# ---------------------------------------------------------------------------

## Радиус зоны обнаружения (px).
@export var aggro_range: float = 250.0

## Угол конуса обнаружения (°). Итоговый — ±aggro_angle/2.
@export var aggro_angle: float = 90.0

# ---------------------------------------------------------------------------
# Патруль
# ---------------------------------------------------------------------------

## Радиус патрульных точек от стартовой позиции (px).
@export var patrol_radius: float = 150.0

# ---------------------------------------------------------------------------
# Прогрессия
# ---------------------------------------------------------------------------

## XP, начисляемый игроку при гибели врага. Слушает LevelXPSystem (#8).
@export var xp_reward: int = 10

## ID таблицы дропа для Лут-системы (#12). Пустая строка = нет лута.
@export var loot_table_id: String = "melee_common"
