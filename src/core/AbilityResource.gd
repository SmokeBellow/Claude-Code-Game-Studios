class_name AbilityResource
extends Resource

## Базовый класс способности. Наследуй и переопредели [method activate].
## [br]
## GDD: [code]design/gdd/ability-system.md[/code]

# ---------------------------------------------------------------------------
# Экспорт (tuning knobs)
# ---------------------------------------------------------------------------

## Отображаемое название способности.
@export var ability_name: String = "Ability"
## Время отката в секундах.
@export var cooldown: float = 3.0

# ---------------------------------------------------------------------------
# Состояние (не экспортируется — runtime данные)
# ---------------------------------------------------------------------------

## Оставшееся время отката.
var _cooldown_remaining: float = 0.0

# ---------------------------------------------------------------------------
# Публичный API
# ---------------------------------------------------------------------------

## Возвращает true если способность готова к использованию.
func is_ready() -> bool:
	return _cooldown_remaining <= 0.0


## Нормализованный прогресс готовности [0..1]. Используется для HUD.
func cooldown_progress() -> float:
	if cooldown <= 0.0:
		return 1.0
	return 1.0 - clampf(_cooldown_remaining / cooldown, 0.0, 1.0)


## Активирует способность. Переопредели в подклассе.
## Возвращает true если способность успешно активирована.
func activate(_owner: Node) -> bool:
	return false


## Обновляет таймер отката. Вызывай каждый кадр из владельца.
func update(delta: float) -> void:
	if _cooldown_remaining > 0.0:
		_cooldown_remaining -= delta

# ---------------------------------------------------------------------------
# Защищённые методы
# ---------------------------------------------------------------------------

## Запускает откат. Вызывается из activate() при успешной активации.
func _start_cooldown() -> void:
	_cooldown_remaining = cooldown
